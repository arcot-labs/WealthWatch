{
    "name": "@arcot-labs/wealthwatch-shared",
    "version": "6.0.22",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arcot-labs/WealthWatch.git"
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rm -rf dist/ && tspc -p tsconfig.build.json",
        "dev": "tspc --watch -p tsconfig.build.json",
        "lint": "eslint --fix --max-warnings=0 src",
        "test": "vitest dev --coverage --ui",
        "test:deploy": "vitest run --coverage"
    },
    "lint-staged": {
        "*": [
            "eslint --fix --max-warnings=0 --no-warn-ignored",
            "prettier --write --ignore-unknown"
        ]
    },
    "dependencies": {
        "@tsconfig/node-lts": "^24.0.0",
        "@tsconfig/strictest": "^2.0.8",
        "plaid": "^42.2.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.6",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "ts-patch": "^4.0.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.6"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    }
}
