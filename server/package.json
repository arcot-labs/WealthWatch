{
    "name": "wealthwatch-server",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "rm -rf dist/ && tsc -p tsconfig.build.json",
        "dev": "dotenvx run -f ../config/env/.env.dev -- tsx watch --inspect src/main.ts",
        "lint": "eslint --fix --max-warnings=0 src",
        "start": "dotenvx run -f ../config/env/.env.dev -- tsx --inspect src/main.ts",
        "start:deploy": "dotenvx run -- tsx src/main.ts",
        "test": "dotenvx run -f ../config/env/.env.dev -- vitest dev --coverage --ui",
        "test:deploy": "dotenvx run -- vitest run --coverage"
    },
    "lint-staged": {
        "*": [
            "eslint --fix --max-warnings=0 --no-warn-ignored",
            "prettier --write --ignore-unknown"
        ]
    },
    "dependencies": {
        "@arcot-labs/wealthwatch-shared": "^6.0.23",
        "@dotenvx/dotenvx": "^1.71.0",
        "@logtail/pino": "^0.5.8",
        "@tsconfig/node-lts": "^24.0.0",
        "@tsconfig/strictest": "^2.0.8",
        "axios": "^1.16.1",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.77.7",
        "connect-pg-simple": "^10.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "date-fns": "^4.4.0",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "helmet": "^8.2.0",
        "ioredis": "5.10.1",
        "jose": "^6.2.3",
        "js-sha256": "^0.11.1",
        "jwt-decode": "^4.0.0",
        "method-override": "^3.0.0",
        "pg": "^8.21.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "plaid": "^42.2.0",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "tsx": "^4.22.4",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/connect-pg-simple": "^7.0.3",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/method-override": "^3.0.0",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.8",
        "@vitest/ui": "^4.1.6",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.6"
    }
}
